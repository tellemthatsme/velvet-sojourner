# AI Agent Starter Kit - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: LLM Provider API Keys
# =============================================================================

# OpenAI (ChatGPT, GPT-4, etc.)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude, Claude Opus, etc.)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google AI (Gemini, PaLM, etc.)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key

# OpenRouter (Access 100+ models)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# =============================================================================
# OPTIONAL: Additional Providers
# =============================================================================

# Azure OpenAI
AZURE_API_KEY=your-azure-key
AZURE_API_BASE=https://your-resource.openai.azure.com
AZURE_API_VERSION=2024-02-01

# Cohere
COHERE_API_KEY=your-cohere-key

# Mistral AI
MISTRAL_API_KEY=your-mistral-key

# =============================================================================
# LiteLLM Proxy Configuration
# =============================================================================

# Master key for LiteLLM proxy API
LITELLM_MASTER_KEY=sk-litellm-master-key-change-this

# Salt key for encryption (generate with: openssl rand -hex 32)
LITELLM_SALT_KEY=your-salt-key-here

# =============================================================================
# Database & Storage
# =============================================================================

# PostgreSQL (for production deployments)
DATABASE_URL=postgresql://user:pass@localhost:5432/aiagents

# Redis (for caching and message broker)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable tracing (OpenTelemetry)
ENABLE_TRACING=false

# Prometheus metrics endpoint
METRICS_PORT=9090

# =============================================================================
# Security
# =============================================================================

# JWT secret for API authentication
JWT_SECRET=your-jwt-secret-change-this-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting: requests per minute
RATE_LIMIT_RPM=60

# =============================================================================
# Feature Flags
# =============================================================================

# Enable specific agent types
ENABLE_CREWAI=true
ENABLE_AUTOGEN=true
ENABLE_LANGCHAIN=true
ENABLE_AIDER=false

# Enable MCP servers
ENABLE_CONTEXT7=true
ENABLE_SUPABASE_MCP=false
ENABLE_GIT_MCP=true

# =============================================================================
# Deployment Settings
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Domain (for production)
DOMAIN=localhost

# SSL/TLS certificate paths (for production)
SSL_CERT_PATH=
SSL_KEY_PATH=

# =============================================================================
# Contact & Support
# =============================================================================

# Admin email for notifications
ADMIN_EMAIL=admin@yourdomain.com

# Support webhook URL (Discord, Slack, etc.)
SUPPORT_WEBHOOK_URL=
