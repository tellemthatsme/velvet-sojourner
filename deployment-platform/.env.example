# AgentForge Environment Configuration
# Copy this file to .env and fill in your values

# Core Platform
LITELLM_MASTER_KEY=sk-agentforge-master-key
WEBUI_SECRET_KEY=agentforge-webui-secret
N8N_PASSWORD=agentforge123
GRAFANA_PASSWORD=agentforge
DEPLOYER_SECRET=agentforge-deployer-secret

# LLM Provider API Keys (add the ones you use)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
OPENROUTER_API_KEY=sk-your-openrouter-key

# Paths
REPOS_DIR=C:/temp/velvet-sojourner/repos
DEPLOYMENTS_DIR=C:/temp/velvet-sojourner/deployment-platform/deployments

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentforge
REDIS_URL=redis://localhost:6379

# Domain (for production)
DOMAIN=localhost
