# =============================================================================
# AI Automation Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys and settings
# =============================================================================

# =============================================================================
# OpenAI Configuration (Required for most features)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# GitHub Configuration (for sync.py)
# =============================================================================
GITHUB_TOKEN=ghp_your-github-token-here

# =============================================================================
# Google Drive Configuration (for sync_drive.sh)
# =============================================================================
# Configure with: rclone config
RCLONE_DRIVE_REMOTE=gdrive
# RCLONE_CONFIG_PATH=~/.config/rclone/rclone.conf

# =============================================================================
# Twitter/X Configuration (for send_posts.py)
# =============================================================================
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# =============================================================================
# Bluesky Configuration (for send_posts.py)
# =============================================================================
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-bsky-app-password

# =============================================================================
# Post Generator Settings
# =============================================================================
DEFAULT_POST_TOPIC=AI automation and productivity
POST_TEMPERATURE=0.8

# =============================================================================
# RAG Embedder Settings
# =============================================================================
EMBED_MODEL=text-embedding-3-small
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =============================================================================
# Dashboard Settings
# =============================================================================
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8080

# =============================================================================
# API Server Ports
# =============================================================================
PROMPT_API_PORT=5000
SEARCH_API_PORT=5001

# =============================================================================
# Paths
# =============================================================================
# BASE_DIR is automatically detected
# PROMPTS_DIR=./prompts
# VECTOR_STORE_DIR=./vector_store
# EXPORTS_DIR=./exports

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
