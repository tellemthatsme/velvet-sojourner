{
    "manifest_version": 3,
    "name": "AI Chat Scraper",
    "version": "1.0.0",
    "description": "Auto-scrape and export chats from lovable.dev, v0.dev, and bolt.new",
    "author": "AI Automation Stack",
    "homepage_url": "https://github.com/yourusername/ai-automation-stack",
    "icons": {
        "16": "icon-16.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "action": {
        "default_title": "AI Chat Scraper",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon-16.png",
            "48": "icon-48.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.lovable.dev/*",
                "*://*.v0.dev/*",
                "*://*.bolt.new/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "*://*.lovable.dev/*",
        "*://*.v0.dev/*",
        "*://*.bolt.new/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "popup.html",
                "popup.js",
                "styles.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}